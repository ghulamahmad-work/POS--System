{
"name": "Turborepo",
  "private": true,
  "scripts": {
    "generate": "npm run generate:pakistan && npm run generate:dubai",
    "generate:pakistan": "npm --prefix packages/database-prisma exec prisma generate -- --schema packages/database-prisma/prisma/pakistan/schema.prisma",
    "generate:dubai": "npm --prefix packages/database-prisma exec prisma generate -- --schema packages/database-prisma/prisma/dubai/schema.prisma",
    "prebuild": "npm run generate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
