generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/pakistan-client"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("PAKISTAN_DATABASE_URL")
}

model Product {
  id              String   @id @default(uuid())
  name            String
  price           Float
  stock           Int
  category        String
  voltage         String?
  warrantyMonths  Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sale {
  id          String     @id @default(uuid())
  totalAmount Float
  taxAmount   Float
  paymentType String
  createdAt   DateTime   @default(now())
  items       SaleItem[]
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id])
  productId  String
  quantity   Int
  unitPrice  Float
}

model Vendor {
  id            String          @id @default(uuid())
  name          String
  contactPhone  String?
  createdAt     DateTime        @default(now())
  purchaseOrders PurchaseOrder[]
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  vendorId    String
  vendor      Vendor              @relation(fields: [vendorId], references: [id])
  status      String              @default("pending")
  totalAmount Float
  createdAt   DateTime            @default(now())
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  productId       String
  quantity        Int
  unitCost        Float
}
