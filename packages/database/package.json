{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./dubai": "./src/dubai.ts",
    "./pakistan": "./src/pakistan.ts",
    "./products": "./src/products.ts",
    "./sales": "./src/sales.ts",
    "./purchases": "./src/purchases.ts"
  },
  "scripts": {
    "db:generate:pakistan": "prisma generate --schema=./prisma-pakistan/schema.prisma",
    "db:generate:dubai": "prisma generate --schema=./prisma-dubai/schema.prisma",

    "db:migrate:pakistan": "prisma migrate dev --schema=./prisma-pakistan/schema.prisma",
    "db:migrate:dubai": "prisma migrate dev --schema=./prisma-dubai/schema.prisma",

    "postinstall": "npm run db:generate:pakistan && npm run db:generate:dubai"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "prisma": "^6.0.0",
    "typescript": "^5.5.4"
  }
}